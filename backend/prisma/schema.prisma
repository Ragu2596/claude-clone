generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  avatar         String?
  googleId       String?   @unique
  password       String?

  // ── Plan ──────────────────────────────────────────────────
  plan           String    @default("free")
  planExpiresAt  DateTime?
  planPaymentId  String?

  // ── API Cost Tracking (auto-managed) ─────────────────────
  // Stores actual cost in micro-dollars (1 USD = 1,000,000 units)
  // So $1.50 = 1,500,000. Using int avoids float precision issues.
  apiCostUsed    Int       @default(0)   // this month's usage
  apiCostLimit   Int       @default(0)   // monthly budget for their plan
  apiCostReset   DateTime  @default(now()) // when the monthly budget resets

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversations  Conversation[]
  projects       Project[]
  payments       Payment[]
  apiUsageLogs   ApiUsageLog[]

  @@index([email])
  @@index([googleId])
}

// ── Per-message API cost log ───────────────────────────────
model ApiUsageLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model          String   // e.g. "claude-sonnet-4-20250514"
  provider       String   // e.g. "anthropic"
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  costMicro      Int      @default(0)   // cost in micro-dollars
  fromCache      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([model])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String
  paymentId String
  plan      String
  billing   String   @default("monthly")
  amount    Int
  status    String   @default("paid")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
}

model Project {
  id            String         @id @default(uuid())
  name          String
  description   String?
  systemPrompt  String?        @default("You are a helpful AI assistant.")
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

model Conversation {
  id        String    @id @default(uuid())
  title     String    @default("New Chat")
  userId    String
  projectId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(uuid())
  role           String
  content        String       @db.Text
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fileUrl        String?
  fileName       String?
  fileType       String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model KnowledgeCache {
  id           String   @id @default(uuid())
  questionHash String   @unique
  question     String   @db.Text
  answer       String   @db.Text
  model        String
  hitCount     Int      @default(1)
  savedCost    Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([questionHash])
  @@index([hitCount])
  @@index([createdAt])
}

model CacheStats {
  id          String   @id @default(uuid())
  date        DateTime @default(now()) @db.Date
  totalHits   Int      @default(0)
  totalMisses Int      @default(0)
  costSaved   Float    @default(0)

  @@index([date])
}
