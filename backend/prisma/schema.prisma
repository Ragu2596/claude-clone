generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  avatar         String?
  googleId       String?   @unique
  password       String?

  // ── Plan ──────────────────────────────────────────────────
  plan           String    @default("free")
  billing        String    @default("monthly")
  planExpiresAt  DateTime?
  planPaymentId  String?

  // ── API Cost Tracking (auto-managed) ─────────────────────
  // Stores actual cost in micro-dollars (1 USD = 1,000,000 units)
  // So $1.50 = 1,500,000. Using int avoids float precision issues.
  apiCostUsed    Int       @default(0)   // this month's usage
  apiCostLimit   Int       @default(0)   // monthly budget for their plan
  apiCostReset   DateTime  @default(now()) // when the monthly budget resets

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversations  Conversation[]
  projects       Project[]
  payments       Payment[]
  memory         UserMemory?
  apiUsageLogs   ApiUsageLog[]
  feedbacks      UserFeedback[]

  @@index([email])
  @@index([googleId])
}

// ── Per-message API cost log ───────────────────────────────
model ApiUsageLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model          String   // e.g. "claude-sonnet-4-20250514"
  provider       String   // e.g. "anthropic"
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  costMicro      Int      @default(0)   // cost in micro-dollars
  fromCache      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([model])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String
  paymentId String
  plan      String
  billing   String   @default("monthly")
  amount    Int
  status    String   @default("paid")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
}

model Project {
  id            String         @id @default(uuid())
  name          String
  description   String?
  systemPrompt  String?        @default("You are a helpful AI assistant.")
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
}

model Conversation {
  id        String    @id @default(uuid())
  title     String    @default("New Chat")
  userId    String
  projectId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(uuid())
  role           String
  content        String       @db.Text
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fileUrl        String?
  fileName       String?
  fileType       String?
  modelUsed      String?      // e.g. "claude-sonnet-4-6" — for per-model daily limits
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([modelUsed, createdAt])
}

// ── rk.ai Knowledge Engine ───────────────────────────────────
// This is rk.ai's core competitive moat.
// Every API call builds this DB. Over time rk.ai serves from
// its own knowledge — independent of any external provider.

model KnowledgeCache {
  id           String   @id @default(uuid())
  questionHash String   @unique          // sha256 of normalized question
  question     String   @db.Text         // original question
  answer       String   @db.Text         // best answer so far
  model        String                    // which model generated it
  topic        String   @default("general") // coding|math|writing|science|general
  language     String   @default("en")   // response language
  hitCount     Int      @default(1)      // times served from cache
  quality      Float    @default(0.5)    // auto-scored 0-1 (answer quality)
  verified     Boolean  @default(false)  // manually verified by admin
  savedCost    Float    @default(0)      // cumulative $ saved by caching
  embedding    Unsupported("vector(768)")?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  feedbacks    UserFeedback[]            // thumbs up/down from users

  @@index([questionHash])
  @@index([hitCount])
  @@index([topic])
  @@index([quality])
  @@index([createdAt])
}

// User feedback on cached answers — improves quality over time
model UserFeedback {
  id         String         @id @default(uuid())
  cacheId    String
  userId     String
  rating     Int            // 1 = thumbs up, -1 = thumbs down
  createdAt  DateTime       @default(now())

  cache      KnowledgeCache @relation(fields: [cacheId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cacheId, userId])  // one vote per user per answer
  @@index([cacheId])
}

model CacheStats {
  id          String   @id @default(uuid())
  date        DateTime @default(now()) @db.Date
  totalHits   Int      @default(0)
  totalMisses Int      @default(0)
  costSaved   Float    @default(0)

  @@index([date])
}

// ── Auto-discovered model registry ───────────────────────────
model ModelConfig {
  id           String   @id @default(uuid())
  modelId      String   @unique   // actual API model id
  provider     String             // groq | openai | anthropic | gemini | mistral | together | perplexity
  group        String             // for frontend grouping
  displayName  String             // unique rk.ai name e.g. "Apex"
  badge        String   @default("FREE")
  color        String   @default("#6b7280")
  requiredPlan String?            // null=free, starter, pro, max
  enabled      Boolean  @default(true)
  isNew        Boolean  @default(true)  // shows NEW badge for 7 days
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider])
  @@index([enabled])
}

// ── Free trial usage per model per user ──────────────────────
model ModelTrial {
  id        String   @id @default(uuid())
  userId    String
  modelId   String
  useCount  Int      @default(0)   // how many trial msgs used
  exhausted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, modelId])
  @@index([userId])
}

// ── Admin Users (role-based access) ──────────────────────────
// Super admin adds emails here with a role
// Only emails in this table can access /#/admin
model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String   @default("")
  role      String   @default("viewer")  // superadmin | admin | viewer
  addedBy   String                       // email of who added them
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model UserMemory {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory    String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([userId])
}
